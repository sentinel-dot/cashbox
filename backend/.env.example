# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cashbox
DB_USER=app_user
DB_PASSWORD=changeme

# Database users (separate per permission level)
DB_AUDIT_USER=audit_insert_user
DB_AUDIT_PASSWORD=changeme
DB_READONLY_USER=app_readonly
DB_READONLY_PASSWORD=changeme

# JWT
JWT_SECRET=change-me-min-32-chars-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Fiskaly (Cloud-TSE)
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe-Preis-IDs für Abonnement-Pläne (aus Stripe Dashboard > Produkte)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
