# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cashbox
DB_USER=app_user
DB_PASSWORD=changeme

# Database users (separate per permission level)
DB_AUDIT_USER=audit_insert_user
DB_AUDIT_PASSWORD=changeme
DB_READONLY_USER=app_readonly
DB_READONLY_PASSWORD=changeme

# JWT
JWT_SECRET=change-me-min-32-chars-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Absolutes Session-Limit in Stunden: Refresh-Rotation verlängert nicht darüber hinaus (Schicht-Modell)
SESSION_MAX_HOURS=16

# Fiskaly (Cloud-TSE)
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe-Preis-IDs für Abonnement-Pläne (aus Stripe Dashboard > Produkte)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# CORS — nur in Production ausgewertet (app.ts). Ohne Wert lehnt der Server
# in Production ALLE Cross-Origin-Requests ab.
ALLOWED_ORIGIN=

# Logging (Pino): trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# E-Mail (Resend, REST). Leer = Dry-Run: es wird nichts versendet, nur geloggt.
# In Production setzen — sonst geht keine Trial-Warnung und keine KassenSichV-Meldung raus.
RESEND_API_KEY=
# Absender MUSS auf der bei Resend verifizierten Domain liegen (SPF/DKIM/DMARC),
# sonst landen die Mails im Spam.
MAIL_FROM=cashbox <noreply@cashbox.de>
# Basis-URL für Links in E-Mails (z.B. Abo-CTA)
APP_URL=https://app.cashbox.de
# Öffentlich erreichbare Basis-URL DIESES Backends. Der Passwort-Reset-Link (S08)
# zeigt hierher, weil die Reset-Seite serverseitig gerendert wird. Muss von außen
# per HTTPS erreichbar sein — sonst läuft jeder Reset-Link ins Leere.
PUBLIC_API_URL=https://api.cashbox.de

# Error-Monitoring (Sentry). Leer = Sentry komplett aus (Dev/Test).
# In Production setzen — sonst sieht niemand die 5xx beim Kunden.
SENTRY_DSN=

# Hintergrund-Jobs (S07, src/cron.ts). Standard: an.
# `false` schaltet ALLE zeitgesteuerten Jobs in diesem Prozess ab — nötig, sobald
# mehrere Instanzen laufen (dann genau eine Instanz mit Jobs) oder für lokale
# Läufe ohne Mailversand/Nachsignierung. Zeitplan-Zone ist immer Europe/Berlin.
CRON_ENABLED=true
