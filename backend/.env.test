NODE_ENV=test
PORT=3001

# Test-Datenbank (cashbox_test)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cashbox_test
DB_USER=app_user_test
DB_PASSWORD=test_password

DB_AUDIT_USER=audit_insert_user_test
DB_AUDIT_PASSWORD=test_password

DB_READONLY_USER=app_readonly_test
DB_READONLY_PASSWORD=test_password

# JWT — fixer Testwert, kein Prod-Secret
JWT_SECRET=test-secret-min-32-chars-xxxxxxxxx
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Admin-Credentials für npm run db:setup:test
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

# Fiskaly + Stripe — nur für test:external nötig, Werte kommen aus .env
