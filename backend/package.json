{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run src/__tests__/unit src/__tests__/compliance",
    "test:integration": "vitest run src/__tests__/integration",
    "test:external": "vitest run --config vitest.external.config.ts src/__tests__/external",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:test": "DOTENV_CONFIG_PATH=.env.test ts-node -r dotenv/config src/db/migrate.ts",
    "db:setup": "ts-node scripts/setup-db.ts",
    "db:setup:test": "DOTENV_CONFIG_PATH=.env.test ts-node scripts/setup-db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
